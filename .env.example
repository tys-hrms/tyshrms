# MongoDB Atlas Connection
# Copy to .env.local for local development
# Add to Vercel Dashboard > Project > Settings > Environment Variables for production

# Your full Atlas connection string (replace <password> and <cluster>)
MONGODB_URI=mongodb+srv://tys_admin:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Optional: override the database name (defaults to tys_hrms)
MONGODB_DB=tys_hrms
